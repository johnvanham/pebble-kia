# Single shared bearer token. Generate with `openssl rand -hex 32`. Required.
PROXY_BEARER_TOKEN=

# demo | live. Only demo is implemented in phase 2; live is a stub that 501s.
DATA_SOURCE=demo

# Path (relative to the process cwd) of the demo JSON file. Re-read on every
# fetch so edits surface on the next forced refresh.
DEMO_DATA_FILE=demo-data.json

# Minimum seconds between live pulls per vehicle. Cached responses are served
# while fresher than this; force=1 or POST /refresh bypasses.
LIVE_REFRESH_MIN_SECONDS=600

# Same knob but for the demo source. Kept short so scenario progression
# surfaces to the watch without needing a long-press refresh every tick.
DEMO_REFRESH_MIN_SECONDS=5

# Background transition detector poll interval.
DETECTOR_INTERVAL_SECONDS=20

# ntfy push target. Leave NTFY_URL empty to disable push — transitions
# are still detected and logged, but nothing is sent anywhere. Set both
# URL and TOPIC to enable. Topic is a guess-hard string chosen by you;
# don't rely on it for auth on public ntfy.sh.
NTFY_URL=
NTFY_TOPIC=
# Only needed for self-hosted ntfy running with auth enabled.
NTFY_AUTH_TOKEN=

# Public-facing URL for the self-hosted ntfy (used by the phone app to
# subscribe). Only relevant when running via docker compose — the
# proxy itself reaches ntfy directly over the compose network.
NTFY_PUBLIC_URL=https://ntfy.example.com

LOG_LEVEL=info
